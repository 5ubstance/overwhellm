[0m\n    yield[0m\n    models.clear()[0m\n[0m\n[0m\napp = FastAPI([0m\n    title=[0m\"Model Runner[0m\",[0m\n    description=[0m\"Anthropic API Compatible - Works with Claude Code & Agentic Tools[0m\",[0m\n    version=[0m\"1.1.0[0m\",[0m\n    lifespan=lifespan,[0m\n    docs_url=[0m\"/api/docs[0m\",[0m\n    redoc_url=[0m\"/api/redoc[0m\"[0m\n)[0m\n[0m\n# CORS for agentic tools[0m\napp.add_middleware([0m\n    CORSMiddleware,[0m\n    allow_origins=[[0m\"*[0m\"],[0m\n    allow_credentials=True,[0m\n    allow_methods=[[0m\"*[0m\"],[0m\n    allow_headers=[[0m\"*[0m\"],[0m\n)[0m\n[0m\n[0m\n# ============== Anthropic Error Handling ==============[0m\n[0m\nclass AnthropicError(BaseModel):[0m\n    type: str[0m\n    message: str[0m\n[0m\n[0m\nclass AnthropicErrorResponse(BaseModel):[0m\n    type: str = [0m\"error[0m\"[0m\n    error: AnthropicError[0m\n[0m\n[0m\ndef create_error_response(status_code: int, error_type: str, message: str) -> JSONResponse:[0m\n    [0m\"[0m\"[0m\"Create Anthropic-compatible error response.[0m\"[0m\"[0m\"[0m\n    return JSONResponse([0m\n        status_code=status_code,[0m\n        content={[0m\n            [0m\"type[0m\": [0m\"error[0m\",[0m\n            [0m\"error[0m\": {[0m\n                [0m\"type[0m\": error_type,[0m\n                [0m\"message[0m\": message[0m\n            }[0m\n        }[0m\n    )[0m\n[0m\n[0m\n@app.exception_handler(RequestValidationError)[0m\nasync def validation_exception_handler(request: Request, exc: RequestValidationError):[0m\n    [0m\"[0m\"[0m\"Handle validation errors (400 - invalid_request_error).[0m\"[0m\"[0m\"[0m\n    errors = exc.errors()[0m\n    message = [0m\"; [0m\".join([f[0m\"{e['loc'][-1]}: {e['msg']}[0m\" for e in errors])[0m\n    return create_error_response(400, [0m\"invalid_request_error[0m\", message)[0m\n[0m\n[0m\n@app.exception_handler(HTTPException)[0m\nasync def http_exception_handler(request: Request, exc: HTTPException):[0m\n    [0m\"[0m\"[0m\"Handle HTTP exceptions with Anthropic error format.[0m\"[0m\"[0m\"[0m\n    error_mapping = {[0m\n        400: [0m\"invalid_request_error[0m\",[0m\n        401: [0m\"authentication_error[0m\",[0m\n        403: [0m\"permission_error[0m\",[0m\n        404: [0m\"not_found_error[0m\",[0m\n        413: [0m\"request_too_large[0m\",[0m\n        429: [0m\"rate_limit_error[0m\",[0m\n        500: [0m\"api_error[0m\",[0m\n        529: [0m\"overloaded_error[0m\"[0m\n    }[0m\n    error_type = error_mapping.get(exc.status_code, [0m\"api_error[0m\")[0m\n    return create_error_response(exc.status_code, error_type, str(exc.detail))[0m\n[0m\n[0m\n@app.exception_handler(Exception)[0m\nasync def general_exception_handler(request: Request, exc: Exception):[0m\n    [0m\"[0m\"[0m\"Handle unexpected errors (500 - api_error).[0m\"[0m\"[0m\"[0m\n    return create_error_response(500, [0m\"api_error[0m\", f[0m\"An unexpected error occurred: {str(exc)}[0m\")[0m\n[0m\n[0m\n# ============== Anthropic API Models ==============[0m\n[0m\nclass TextBlock(BaseModel):[0m\n    type: Literal[[0m\"text[0m\"] = [0m\"text[0m\"[0m\n    text: str[0m\n[0m\n[0m\nclass ThinkingBlock(BaseModel):[0m\n    type: Literal[[0m\"thinking[0m\"] = [0m\"thinking[0m\"[0m\n    thinking: str[0m\n[0m\n[0m\nclass SignatureBlock(BaseModel):[0m\n    type: Literal[[0m\"signature[0m\"] = [0m\"signature[0m\"[0m\n    signature: str[0m\n[0m\n[0m\nclass ToolUseBlock(BaseModel):[0m\n    type: Literal[[0m\"tool_use[0m\"] = [0m\"tool_use[0m\"[0m\n    id: str[0m\n    name: str[0m\n    input: Dict[str, Any][0m\n[0m\n[0m\nclass ToolResultContent(BaseModel):[0m\n    type: Literal[[0m\"tool_result[0m\"] = [0m\"tool_result[0m\"[0m\n    tool_use_id: str[0m\n    content: Union[str, List[TextBlock]][0m\n    is_error: Optional[bool] = False[0m\n[0m\n[0m\nclass ImageSource(BaseModel):[0m\n