return [0m\" [0m\".join([block.text for block in system if hasattr(block, 'text')])[0m\n[0m\n[0m\ndef format_messages_to_prompt(messages: List[MessageParam], system: Optional[Union[str, List[TextBlock]]] = None, include_thinking: bool = False) -> str:[0m\n    prompt_parts = [][0m\n    system_text = format_system_prompt(system)[0m\n    if system_text:[0m\n        prompt_parts.append(f[0m\"System: {system_text}[0m\\n[0m\\n[0m\")[0m\n    for msg in messages:[0m\n        role = msg.role[0m\n        content = msg.content[0m\n        if isinstance(content, list):[0m\n            for block in content:[0m\n                if isinstance(block, dict):[0m\n                    block_type = block.get('type', 'text')[0m\n                    if block_type == 'thinking' and include_thinking:[0m\n                        prompt_parts.append(f[0m\"<thinking>{block.get('thinking', '')}</thinking>[0m\\n[0m\")[0m\n                    elif block_type == 'text':[0m\n                        text_content = block.get('text', '')[0m\n                        if role == [0m\"user[0m\":[0m\n                            prompt_parts.append(f[0m\"Human: {text_content}[0m\\n[0m\\n[0m\")[0m\n                        else:[0m\n                            prompt_parts.append(f[0m\"Assistant: {text_content}[0m\\n[0m\\n[0m\")[0m\n                    elif block_type == 'tool_result':[0m\n                        prompt_parts.append(f[0m\"Tool Result: {block.get('content', '')}[0m\\n[0m\\n[0m\")[0m\n                elif hasattr(block, 'type'):[0m\n                    if block.type == 'thinking' and include_thinking:[0m\n                        prompt_parts.append(f[0m\"<thinking>{block.thinking}</thinking>[0m\\n[0m\")[0m\n                    elif block.type == 'text':[0m\n                        if role == [0m\"user[0m\":[0m\n                            prompt_parts.append(f[0m\"Human: {block.text}[0m\\n[0m\\n[0m\")[0m\n                        else:[0m\n                            prompt_parts.append(f[0m\"Assistant: {block.text}[0m\\n[0m\\n[0m\")[0m\n        else:[0m\n            content_text = content if isinstance(content, str) else extract_text_from_content(content)[0m\n            if role == [0m\"user[0m\":[0m\n                prompt_parts.append(f[0m\"Human: {content_text}[0m\\n[0m\\n[0m\")[0m\n            elif role == [0m\"assistant[0m\":[0m\n                prompt_parts.append(f[0m\"Assistant: {content_text}[0m\\n[0m\\n[0m\")[0m\n    prompt_parts.append([0m\"Assistant:[0m\")[0m\n    return [0m\"[0m\".join(prompt_parts)[0m\n[0m\n[0m\ndef generate_text(prompt: str, max_tokens: int, temperature: float, top_p: float) -> tuple:[0m\n    tokenizer = models[[0m\"tokenizer[0m\"][0m\n    model = models[[0m\"model[0m\"][0m\n    inputs = tokenizer(prompt, return_tensors=[0m\"pt[0m\", truncation=True, max_length=1024)[0m\n    input_tokens = inputs[[0m\"input_ids[0m\"].shape[1][0m\n    with torch.no_grad():[0m\n        outputs = model.generate([0m\n            **inputs,[0m\n            max_new_tokens=min(max_tokens, 512),[0m\n            temperature=temperature if temperature > 0 else 1.0,[0m\n            top_p=top_p,[0m\n            do_sample=temperature > 0,[0m\n            pad_token_id=tokenizer.pad_token_id,[0m\n            eos_token_id=tokenizer.eos_token_id[0m\n        )[0m\n    generated_tokens = outputs[0][input_tokens:][0m\n    output_tokens = len(generated_tokens)[0m\n    generated_text = tokenizer.decode(generated_tokens, skip_special_tokens=True)[0m\n    return generated_text.strip(), input_tokens, output_tokens[0m\n[0m\n[0m\ndef generate_thinking(prompt: str, budget_tokens: int = 100) -> tuple:[0m\n    tokenizer = models[[0m\"tokenizer[0m\"][0m\n    model = models[[0m\"model[0m\"][0m\n    thinking_prompt = f[0m\"{prompt}[0m\\n[0m\\nLet me think through this step by step:[0m\\n[0m\"[0m\n    inputs = tokenizer(thinking_prompt, return_tensors=[0m\"pt[0m\", truncation=True, max_length=512)[0m\n    input_tokens = inputs[[0m\"input_ids[0m\"].shape[1][0m\n    with torch.no_grad():[0m\n        outputs = model.generate([0m\n            **inputs,[0m\n            max_new_tokens=min(budget_tokens, 256),[0m\n            temperature=0.7,[0m\n            top_p=0.9,[0m\n            do_sample=True,[0m\n            pad_token_id=tokenizer.pad_token_id,[0m\n            eos_token_id=tokenizer.eos_token_id[0m\n        )[0m\n    generated_tokens = outputs[0][input_tokens:][0m\n    thinking_tokens = len(generated_tokens)[0m\n    thinking_text = tokenizer.decode(generated_tokens, skip_special_tokens=True)[0m\n    return thinking_text.strip(), thinking_tokens[0m\n[0m\n[0m\nasync def generate_stream_with_thinking(prompt: str, max_tokens: int, temperature: float, top_p: float, message_id: str, model_name: str, thinking_enabled: bool = False, thinking_budget: int = 100):[0m\n    tokenizer = models[[0m\"tokenizer[0m\"][0m\n    model = models[[0m\"model[0m\"][0m\n    inputs = tokenizer(prompt, return_tensors=[0m\"pt[0m\", truncation=True, max_length=1024)[0m\n    input_tokens = inputs[[0m\"input_ids[0m\"].shape[1][0m\n    total_output_tokens = 0[0m\n[0m\n    message_start = {[0m\n        [0m\"type[0m\": [0m\"message_start[0m\",[0m\n        [0m\"message[0m\": {[0m\"id[0m\": message_id, [0m\"type[0m\": [0m\"message[0m\", [0m\"role[0m\": [0m\"assistant[0m\", [0m\"content[0m\": [], [0m\"model[0m\": model_name, [0m\"stop_reason[0m\": None, [0m\"stop_sequence[0m\": None, [0m\"usage[0m\": {[0m\"input_tokens[0m\": input_tokens, [0m\"output_tokens[0m\": 0}}[0m\n    }[0m\n    yield f[0m\"event: message_start[0m\\ndata: {json.dumps(message_start)}[0m\\n[0m\\n[0m\"[0m\n[0m\n    content_index = 0[0m\n[0m\n    if thinking_enabled:[0m\n        thinking_block_start = {[0m\"type[0m\": [0m\"content_block_start[0m\", [0m\"index[0m\": content_index, [0m