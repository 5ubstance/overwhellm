      [32m"content[0m"[33m:[0m [32m"[0m\"[0m\"[0m\"[0m\nDocker Model Runner - Anthropic API Compatible[0m\nFull compatibility with Anthropic Messages API + Interleaved Thinking[0m\nSupports: /v1/messages, /anthropic/v1/messages, /api/v1/messages[0m\nOptimized for: 2 vCPU, 16GB RAM[0m\n[0m\"[0m\"[0m\"[0m\nfrom fastapi import FastAPI, HTTPException, Header, Request, status[0m\nfrom fastapi.responses import StreamingResponse, HTMLResponse, FileResponse, JSONResponse[0m\nfrom fastapi.exceptions import RequestValidationError[0m\nfrom fastapi.staticfiles import StaticFiles[0m\nfrom fastapi.middleware.cors import CORSMiddleware[0m\nfrom pydantic import BaseModel, Field[0m\nfrom typing import Optional, List, Union, Literal, Any, Dict[0m\nimport torch[0m\nfrom transformers import AutoTokenizer, AutoModelForCausalLM[0m\nimport os[0m\nfrom datetime import datetime[0m\nfrom contextlib import asynccontextmanager[0m\nimport uuid[0m\nimport time[0m\nimport json[0m\nimport asyncio[0m\n[0m\n# CPU-optimized lightweight models[0m\nGENERATOR_MODEL = os.getenv([0m\"GENERATOR_MODEL[0m\", [0m\"distilgpt2[0m\")[0m\nMODEL_DISPLAY_NAME = os.getenv([0m\"MODEL_NAME[0m\", [0m\"MiniMax-M2[0m\")[0m\n[0m\n# Set CPU threading[0m\ntorch.set_num_threads(2)[0m\n[0m\n# Global model cache[0m\nmodels = {}[0m\n[0m\n[0m\ndef load_models():[0m\n    global models[0m\n    print([0m\"Loading models for CPU inference...[0m\")[0m\n    models[[0m\"tokenizer[0m\"] = AutoTokenizer.from_pretrained(GENERATOR_MODEL)[0m\n    models[[0m\"model[0m\"] = AutoModelForCausalLM.from_pretrained(GENERATOR_MODEL)[0m\n    models[[0m\"model[0m\"].eval()[0m\n    if models[[0m\"tokenizer[0m\"].pad_token is None:[0m\n        models[[0m\"tokenizer[0m\"].pad_token = models[[0m\"tokenizer[0m\"].eos_token[0m\n    print([0m\"✅ All models loaded successfully![0m\")[0m\n[0m\n[0m\n@asynccontextmanager[0m\nasync def lifespan(app: FastAPI):[0m\n    load_models()