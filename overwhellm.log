 Request, exc: HTTPException):[0m\n    [0m\"[0m\"[0m\"Handle HTTP exceptions with Anthropic error format.[0m\"[0m\"[0m\"[0m\n    error_mapping = {[0m\n        400: [0m\"invalid_request_error[0m\",[0m\n        401: [0m\"authentication_error[0m\",[0m\n        403: [0m\"permission_error[0m\",[0m\n        404: [0m\"not_found_error[0m\",[0m\n        413: [0m\"request_too_large[0m\",[0m\n        429: [0m\"rate_limit_error[0m\",[0m\n        500: [0m\"api_error[0m\",[0m\n        529: [0m\"overloaded_error[0m\"[0m\n    }[0m\n    error_type = error_mapping.get(exc.status_code, [0m\"api_error[0m\")[0m\n    return create_error_response(exc.status_code, error_type, str(exc.detail))[0m\n[0m\n[0m\n@app.exception_handler(Exception)[0m\nasync def general_exception_handler(request: Request, exc: Exception):[0m\n    [0m\"[0m\"[0m\"Handle unexpected errors (500 - api_error).[0m\"[0m\"[0m\"[0m\n    return create_error_response(500, [0m\"api_error[0m\", f[0m\"An unexpected error occurred: {str(exc)}[0m\")[0m\n[0m\n[0m\n# ============== Anthropic API Models ==============[0m\n[0m\nclass TextBlock(BaseModel):[0m\n    type: Literal[[0m\"text[0m\"] = [0m\"text[0m\"[0m\n    text: str[0m\n[0m\n[0m\nclass ThinkingBlock(BaseModel):[0m\n    type: Literal[[0m\"thinking[0m\"] = [0m\"thinking[0m\"[0m\n    thinking: str[0m\n[0m\n[0m\nclass SignatureBlock(BaseModel):[0m\n    type: Literal[[0m\"signature[0m\"] = [0m\"signature[0m\"[0m\n    signature: str[0m\n[0m\n[0m\nclass ToolUseBlock(BaseModel):[0m\n    type: Literal[[0m\"tool_use[0m\"] = [0m\"tool_use[0m\"[0m\n    id: str[0m\n    name: str[0m\n    input: Dict[str, Any][0m\n[0m\n[0m\nclass ToolResultContent(BaseModel):[0m\n    type: Literal[[0m\"tool_result[0m\"] = [0m\"tool_result[0m\"[0m\n    tool_use_id: str[0m\n    content: Union[str, List[TextBlock]][0m\n    is_error: Optional[bool] = False[0m\n[0m\n[0m\nclass ImageSource(BaseModel):[0m\n    type: Literal[[0m\"base64[0m\", [0m\"url[0m\"][0m\n    media_type: Optional[str] = None[0m\n    data: Optional[str] = None[0m\n    url: Optional[str] = None[0m\n[0m\n[0m\nclass ImageBlock(BaseModel):[0m\n    type: Literal[[0m\"image[0m\"] = [0m\"image[0m\"[0m\n    source: ImageSource[0m\n[0m\n[0m\nContentBlock = Union[TextBlock, ThinkingBlock, SignatureBlock, ToolUseBlock, ToolResultContent, ImageBlock, str][0m\n[0m\n[0m\nclass MessageParam(BaseModel):[0m\n    role: Literal[[0m\"user[0m\", [0m\"assistant[0m\"][0m\n    content: Union[str, List[ContentBlock]][0m\n[0m\n[0m\nclass ToolInputSchema(BaseModel):[0m\n    type: str = [0m\"object[0m\"[0m\n    properties: Optional[Dict[str, Any]] = None[0m\n    required: Optional[List[str]] = None[0m\n[0m\n[0m\nclass Tool(BaseModel):[0m\n    name: str[0m\n    description: str[0m\n    input_schema: ToolInputSchema[0m\n[0m\n[0m\nclass ToolChoice(BaseModel):[0m\n    type: Literal[[0m\"auto[0m\", [0m\"any[0m\", [0m\"tool[0m\"] = [0m\"auto[0m\"[0m\n    name: Optional[str] = None[0m\n    disable_parallel_tool_use: Optional[bool] = False[0m\n[0m\n[0m\nclass ThinkingConfig(BaseModel):[0m\n    type: Literal[[0m\"enabled[0m\", [0m\"disabled[0m\"] = [0m\"disabled[0m\"[0m\n    budget_tokens: Optional[int] = None[0m\n[0m\n[0m\nclass Metadata(BaseModel):[0m\n    user_id: Optional[str] = None[0m\n[0m\n[0m\nclass AnthropicRequest(BaseModel):[0m\n    model: str = [0m\"MiniMax-M2[0m\"[0m\n    messages: List[MessageParam][0m\n    max_tokens: int = 4096[0m\n    temperature: Optional[float] = Field(default=1.0, gt=0.0, le=1.0)[0m\n    top_p: Optional[float] = Field(default=1.0, gt=0.0, le=1.0)[0m\n    top_k: Optional[int] = None[0m\n    stop_sequences: Optional[List[str]] = None[0m\n    stream: Optional[bool] = False[0m\n    system: Optional[Union[str, List[TextBlock]]] = None[0m\n    tools: Optional[List[Tool]] = None[0m\n    tool_choice: Optional[Union[Tool